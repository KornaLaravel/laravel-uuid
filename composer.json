{
	"name" : "webpatser/laravel-uuid",
	"description" : "Laravel integration for webpatser/uuid - High-performance drop-in UUID replacements (15% faster than Ramsey). Provides Str macros, HasUuids trait, facades, and casts. RFC 4122/9562 compliant.",
	"authors" : [{
			"name" : "Christoph Kempen",
			"email" : "christoph@downsized.nl"
		}
	],
	"keywords" : [
		"laravel", "uuid", "performance", "replacement", "ramsey", "facade", "cast", "macro", "hasuuids", "rfc4122", "rfc9562"
	],
	"homepage" : "https://github.com/webpatser/laravel-uuid",
	"license" : [
		"MIT"
	],
	"require" : {
		"php" : "^8.5",
		"webpatser/uuid": "^2.0|dev-main",
		"illuminate/support": "^13.0"
	},
    "require-dev" : {
		"fakerphp/faker": "^1.24",
		"pestphp/pest": "^4.0",
		"illuminate/database": "^13.0"
    },
	"autoload" : {
		"psr-4" : {
			"Webpatser\\LaravelUuid\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"support" : {
		"source" : "https://github.com/webpatser/laravel-uuid",
		"issues" : "https://github.com/webpatser/laravel-uuid/issues"
	},
    "extra": {
        "laravel": {
			"providers": [
				"Webpatser\\LaravelUuid\\UuidServiceProvider"
			],
            "aliases": {
                "Uuid": "Webpatser\\LaravelUuid\\UuidFacade"
            }
        }
    },
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		}
	}
}
